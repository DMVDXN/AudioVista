# Spotify OAuth — register at https://developer.spotify.com/dashboard
# Redirect URI: http://localhost:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Last.fm — get a key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Genius API - create a client at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# Database (optional, only for persistence beyond browser)
DATABASE_URL=
